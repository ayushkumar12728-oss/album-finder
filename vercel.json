{
  "version": 2,
  "builds": [
    { "src": "api/token.js", "use": "@vercel/node" },
    { "src": "*.html",       "use": "@vercel/static" },
    { "src": "*.css",        "use": "@vercel/static" },
    { "src": "*.js",         "use": "@vercel/static",
      "config": { "exclude": ["api/**", "server.js"] }
    }
  ],
  "routes": [
    { "src": "/api/token", "dest": "/api/token.js" },
    { "src": "/(.*)",      "dest": "/$1" }
  ]
}
